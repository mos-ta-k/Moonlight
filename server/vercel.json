{
  "version": 2,
  "builds": [
    {
      "builds": [{ "src": "api/**/*.js", "use": "@vercel/node" }],
      "routes": [{ "src": "/api/(.*)", "dest": "/api/$1" }],
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
